{
  "name": "tg-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontends/*"
  ],
  "scripts": {
    "dev": "npm run dev -w tg-platform-product",
    "dev:demo": "npm run dev -w tg-platform-presentation",
    "build": "npm run build -w tg-platform-product",
    "build:demo": "GITHUB_PAGES=true NEXT_PUBLIC_BASE_PATH=/TG_Platform NEXT_PUBLIC_USE_MSW=1 npm run build -w tg-platform-presentation",
    "start": "npm run start -w tg-platform-product",
    "check": "npm run check --workspaces --if-present"
  },
  "overrides": {
    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1",
    "@emnapi/wasi-threads": "1.2.2"
  }
}
