# Product frontend — talks to the real backend (FastAPI).
# Used inside docker-compose and for local dev against a running backend.

# Disable MSW mocks — use the real API
NEXT_PUBLIC_USE_MSW=0

# Backend base URL (no trailing slash), browser-reachable
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Leave empty for product (served at site root, not a subpath)
NEXT_PUBLIC_BASE_PATH=

# Extra dev origins for next.config allowedDevOrigins (comma-separated, optional)
# DEV_ALLOWED_ORIGINS=192.168.0.16,192.168.0.16:3020
