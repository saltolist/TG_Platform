# TG Platform frontend — один код, два контура сборки (см. docs/dev/deploy.md).

# Data source: 1 = MSW mocks (демо / GitHub Pages), 0 = реальный API (Docker)
NEXT_PUBLIC_USE_MSW=1

# Backend base URL (no trailing slash), browser-reachable — когда MSW выключен
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Base path: пусто для Docker / локального продукта; /TG_Platform для GitHub Pages
NEXT_PUBLIC_BASE_PATH=

# Extra dev origins for next.config allowedDevOrigins (comma-separated, optional)
# DEV_ALLOWED_ORIGINS=192.168.0.16,192.168.0.16:3020
