# --- Database ---
DATABASE_URL=postgresql+asyncpg://tg:tg@localhost:5432/tg

# pytest only — never point tests at `tg` (conftest wipes users after each test)
TEST_DATABASE_URL=postgresql+asyncpg://tg:tg@localhost:5432/tg_test

# --- Auth / JWT ---
JWT_SECRET=change-me-please-generate-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080            # 7 days

# --- CORS (comma-separated browser origins of the frontend) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3020,http://localhost:3021

# --- Email codes (registration / password reset) ---
# If SMTP_HOST is empty, codes are written to the backend logs (dev mode).
EMAIL_CODE_TTL_MINUTES=15
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@tg-platform.local

# --- Object storage (MinIO / S3) — used from Phase 2 ---
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=tg-media

# --- BYOK key encryption (Phase 2, step 5) ---
# Generate: .venv/bin/python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Docker: set in repo root .env (see ../.env.example). Empty = plaintext (dev/test only).
BYOK_ENCRYPTION_KEY=

# --- AI (Phase 2) — optional; leave empty for stub replies in presentation/demo ---
# Local backend: keys are read from this file. Docker: use root .env (see repo .env.example).
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
# Web-search (presentation composer when LLM keys are set)
TAVILY_API_KEY=
PERPLEXITY_API_KEY=
# RAG: 0 = off, 1 = on (requires pgvector image and a real LLM model on the account)
RAG_ENABLED=1
# RAG parameters (optional overrides)
RAG_TOP_K=4
RAG_MIN_SIMILARITY=0.38
RAG_MAX_NOTE_CHARS=4000
# Embeddings: local model by default (no key needed).
# Set EMBEDDING_PROVIDER_BYOK=OpenAI to use BYOK OpenAI embeddings instead.
EMBEDDING_MODEL_LOCAL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_PROVIDER_BYOK=
# LLM debug: AI_CONTEXT_LOG=1, then ./scripts/ai-log-chat.sh <chat-id> on running Docker
AI_CONTEXT_LOG=1
AI_CONTEXT_LOG_CHAT=
