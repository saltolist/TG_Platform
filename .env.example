# docker-compose — заполните и сохраните как .env (НЕ коммитьте .env).

# --- PostgreSQL ---
POSTGRES_USER=tg
POSTGRES_PASSWORD=tg
POSTGRES_DB=tg

# --- Backend ---
# Сгенерируйте длинную случайную строку, напр.: openssl rand -hex 32
JWT_SECRET=change-me-please-generate-a-long-random-string
# Разрешённые origin фронтенда (через запятую)
CORS_ORIGINS=http://localhost:3000,http://localhost:3020
# httpOnly cookie для JWT (браузерный клиент)
# localhost / Docker: COOKIE_SECURE=0, COOKIE_SAMESITE=lax
# Разные домены фронта и API: COOKIE_SECURE=1, COOKIE_SAMESITE=none, COOKIE_DOMAIN=.example.com
COOKIE_SECURE=0
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# --- AI (Фаза 2) — опционально; без ключей презентация/демо получают заглушку ---
# Реальный LLM в Docker: задайте хотя бы один ключ. Сидер demo-full подставит модели
# с apiKey env:<NAME> для провайдеров, чьи ключи не пустые.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
TAVILY_API_KEY=
PERPLEXITY_API_KEY=
# BYOK at-rest (Фаза 2, шаг 5): Fernet-ключ для шифрования ключей в profiles.ai.
# Сгенерировать: backend/.venv/bin/python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Пусто — ключи хранятся plaintext (только dev/test).
BYOK_ENCRYPTION_KEY=
# Ротация ключа: старые Fernet-ключи через запятую (только для дешифровки при ротации).
# После запуска scripts/rotate_byok_key.py очистите это поле.
BYOK_ENCRYPTION_OLD_KEYS=
# RAG (pgvector): 0 — выкл., 1 — вкл. (нужна реальная LLM-модель на аккаунте)
RAG_ENABLED=1
# LLM debug: AI_CONTEXT_LOG=1 в .env, docker compose up как обычно, затем:
#   ./scripts/ai-log-chat.sh <chat-id>
AI_CONTEXT_LOG=1
AI_CONTEXT_LOG_CHAT=
# v2 contextStamp mechanics: 0 — legacy compound labels, 1 — msg-ver-branch + contextStamp JSON
AI_CONTEXT_STAMPS=0

# --- MinIO (S3) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Frontend (build-time) ---
# Browser-reachable URL бэкенда (инлайнится при сборке образа frontend)
PUBLIC_API_URL=http://localhost:8000
