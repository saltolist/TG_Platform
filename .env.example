# docker-compose — заполните и сохраните как .env (НЕ коммитьте .env).

# --- PostgreSQL ---
POSTGRES_USER=tg
POSTGRES_PASSWORD=tg
POSTGRES_DB=tg

# --- Backend ---
# Сгенерируйте длинную случайную строку, напр.: openssl rand -hex 32
JWT_SECRET=change-me-please-generate-a-long-random-string
# Разрешённые origin фронтенда (через запятую)
CORS_ORIGINS=http://localhost:3000

# --- MinIO (S3) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Frontend (build-time) ---
# Browser-reachable URL бэкенда (инлайнится при сборке образа web)
PUBLIC_API_URL=http://localhost:8000
