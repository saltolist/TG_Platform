# Presentation (demo) frontend — always MSW, no backend.
# Deployed to GitHub Pages.

# MSW mocks (keep on for the demo)
NEXT_PUBLIC_USE_MSW=1

# GitHub Pages base path (repo name for project site, e.g. /TG_Platform)
NEXT_PUBLIC_BASE_PATH=

# Extra dev origins for next.config allowedDevOrigins (comma-separated, optional)
# DEV_ALLOWED_ORIGINS=192.168.0.16,192.168.0.16:3021
